@model string

@switch (Model)
{
    case "cloud":
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
        </svg>
        break;
    case "clipboard":
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
            <rect x="8" y="2" width="8" height="4" rx="1"/>
        </svg>
        break;
    case "car":
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M7 17h.01M17 17h.01"/>
            <path d="M5 11l1-4h12l1 4"/>
            <path d="M5 11v6h14v-6"/>
        </svg>
        break;
    case "location":
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11z"/>
            <circle cx="12" cy="10" r="2.5"/>
        </svg>
        break;
    case "settings":
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
        break;
    case "thermometer":
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M14 14.76V5a2 2 0 0 0-4 0v9.76a4 4 0 1 0 4 0z"/>
        </svg>
        break;
    case "droplet":
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
        </svg>
        break;
    case "wind":
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M9.59 4.59A2 2 0 1 1 11 8H2"/>
            <path d="M12.59 19.41A2 2 0 1 0 14 16H2"/>
            <path d="M17.73 7.73A2.5 2.5 0 1 1 19.5 12H2"/>
        </svg>
        break;
    case "sunny":
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f5c542" stroke-width="1.6" aria-hidden="true">
            <circle cx="12" cy="12" r="4" fill="#f5c542"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        break;
    case "rain":
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
            <path d="M8 19v2M12 19v2M16 19v2"/>
        </svg>
        break;
    case "cloudy":
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" fill="#666"/>
        </svg>
        break;
    case "partly-cloudy":
        <svg width="48" height="48" viewBox="0 0 64 64" aria-hidden="true">
            <circle cx="22" cy="22" r="10" fill="#f5c542"/>
            <path d="M18 38h28a10 10 0 0 0 2-19.8A12 12 0 0 0 20 24" fill="none" stroke="#d0d0d0" stroke-width="3"/>
        </svg>
        break;
    default:
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
        </svg>
        break;
}
