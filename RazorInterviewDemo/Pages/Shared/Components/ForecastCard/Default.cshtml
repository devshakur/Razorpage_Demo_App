@model ForecastCardModel

<section class="weather-card rounded-4 p-3" data-forecast-card>
    <div class="weather-panel d-flex rounded-pill p-1 mb-3"
         role="tablist"
         aria-label="Forecast view">
        <button type="button"
                class="btn flex-fill rounded-pill border-0 forecast-tab is-active"
                data-forecast-tab="today"
                role="tab"
                aria-selected="true"
                aria-controls="forecast-panel-today">
            Today, @Model.TodayDateLabel
        </button>
        <button type="button"
                class="btn flex-fill rounded-pill border-0 forecast-tab"
                data-forecast-tab="week"
                role="tab"
                aria-selected="false"
                aria-controls="forecast-panel-week">
            @Model.WeekLabel
        </button>
    </div>

    <div id="forecast-panel-today"
         class="forecast-panel"
         data-forecast-panel="today"
         role="tabpanel">
        @if (Model.TodayHours.Count == 0)
        {
            <p class="text-center mb-0 py-3 weather-text-muted">No hourly forecast available.</p>
        }
        else
        {
            <div data-today-hours-list>
                @for (var index = 0; index < Model.TodayHours.Count; index++)
                {
                    <div data-today-hour-item
                         data-hour-index="@index"
                         class="@(index >= 7 ? "d-none" : string.Empty)">
                        @await Component.InvokeAsync("ForecastItem", Model.TodayHours[index])
                    </div>
                }
            </div>

            @if (Model.TodayHours.Count > 7)
            {
                var totalPages = (int)Math.Ceiling(Model.TodayHours.Count / 7.0);
                <div class="today-pagination d-flex align-items-center justify-content-between mt-2 px-1"
                     data-today-pagination
                     data-total-pages="@totalPages">
                    <button type="button"
                            class="btn btn-sm rounded-pill px-3 today-page-btn"
                            data-today-page="prev"
                            disabled>
                        Previous
                    </button>
                    <span data-today-page-info class="weather-text-muted" style="font-size: 12px;">
                        Page 1 of @totalPages
                    </span>
                    <button type="button"
                            class="btn btn-sm rounded-pill px-3 today-page-btn"
                            data-today-page="next">
                        Next
                    </button>
                </div>
            }
        }
    </div>

    <div id="forecast-panel-week"
         class="forecast-panel d-none"
         data-forecast-panel="week"
         role="tabpanel"
         hidden>
        @foreach (var day in Model.WeekDays)
        {
            @await Component.InvokeAsync("ForecastItem", day)
        }
    </div>
</section>
