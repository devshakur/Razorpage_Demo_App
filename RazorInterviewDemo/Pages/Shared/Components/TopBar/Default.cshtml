@model TopBarModel

<header class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 pb-3"
        style="border-bottom: 1px solid #2a2a2a;">
    <div class="d-flex align-items-center gap-2">
        @foreach (var button in Model.NavButtons)
        {
            @await Component.InvokeAsync("IconButton", button)
        }
    </div>

    <div id="weather-location"
         class="rounded-pill d-inline-flex align-items-center gap-2 px-4 py-2 mx-auto"
         style="background-color: #ffffff; color: #111111; font-weight: 500; min-width: 280px; justify-content: center;">
        @await Html.PartialAsync("_WeatherIcon", "location")
        <span>@Model.Location</span>
    </div>

    <div class="d-flex align-items-center gap-3">
        <span style="color: #ffffff; font-size: 15px;">@Model.Greeting</span>
        @await Component.InvokeAsync("IconButton", new IconButtonModel
        {
            Icon = "settings",
            IsCircular = true,
            Action = "refresh-weather"
        })
        <img src="@Model.AvatarUrl"
             alt="Profile"
             class="rounded-circle"
             style="width: 42px; height: 42px; object-fit: cover; border: 2px solid #3a3a3a;" />
    </div>
</header>
