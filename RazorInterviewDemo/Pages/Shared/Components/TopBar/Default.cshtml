@model TopBarModel

<header class="weather-header d-grid align-items-center gap-3 mb-4 pb-3"
        style="grid-template-columns: 1fr auto 1fr;">
    <div class="d-flex align-items-center gap-2">
        @foreach (var button in Model.NavButtons)
        {
            @await Component.InvokeAsync("IconButton", button)
        }
    </div>

    <div id="weather-location"
         class="weather-location-pill rounded-pill d-inline-flex align-items-center gap-2 px-4 py-2">
        @await Html.PartialAsync("_WeatherIcon", "location")
        <span>@Model.Location</span>
    </div>

    <div class="d-flex align-items-center justify-content-end">
        @await Component.InvokeAsync("IconButton", Model.SettingsButton)
    </div>
</header>
