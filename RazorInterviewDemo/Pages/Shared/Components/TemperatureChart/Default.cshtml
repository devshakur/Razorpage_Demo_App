@model TemperatureChartModel
@using System.Globalization

@{
    const int chartWidth = 640;
    const int chartHeight = 280;
    const int paddingLeft = 40;
    const int paddingRight = 20;
    const int paddingTop = 20;
    const int paddingBottom = 50;
    var minTemp = Model.MinTemperature;
    var maxTemp = Model.MaxTemperature;
    var tempRange = Math.Max(maxTemp - minTemp, 1);
    var tickStep = tempRange <= 10 ? 2 : 5;

    var plotWidth = chartWidth - paddingLeft - paddingRight;
    var plotHeight = chartHeight - paddingTop - paddingBottom;
    var points = Model.Points.ToList();
    var count = points.Count;

    string BuildPath(Func<ChartDataPointModel, int> selector)
    {
        if (count == 0)
        {
            return string.Empty;
        }

        var segments = new List<string>();
        for (var i = 0; i < count; i++)
        {
            var x = paddingLeft + (plotWidth / Math.Max(count - 1, 1)) * i;
            var value = selector(points[i]);
            var y = paddingTop + plotHeight - ((value - minTemp) / (double)tempRange * plotHeight);
            segments.Add($"{(i == 0 ? "M" : "L")}{x.ToString(CultureInfo.InvariantCulture)},{y.ToString(CultureInfo.InvariantCulture)}");
        }

        return string.Join(" ", segments);
    }

    var averagePath = BuildPath(p => p.Average);
    var maximumPath = BuildPath(p => p.Maximum);
    var minimumPath = BuildPath(p => p.Minimum);
}

<section class="rounded-4 p-4 h-100"
         style="background-color: #1a1a1a; border: 1px solid #2a2a2a; min-height: 420px;">
    <div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
        <h2 class="h5 mb-0" style="color: #ffffff;">@Model.Title</h2>
        <div class="d-flex gap-3 flex-wrap" style="font-size: 12px; color: #aaaaaa;">
            <span class="d-inline-flex align-items-center gap-1">
                <span class="rounded-circle d-inline-block" style="width: 8px; height: 8px; background-color: #ffffff;"></span>
                average
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="rounded-circle d-inline-block" style="width: 8px; height: 8px; background-color: #f59e42;"></span>
                maximum
            </span>
            <span class="d-inline-flex align-items-center gap-1">
                <span class="rounded-circle d-inline-block" style="width: 8px; height: 8px; background-color: #4da3ff;"></span>
                minimum
            </span>
        </div>
    </div>

    @if (count == 0)
    {
        <p class="text-center mb-0 py-5" style="color: #888888;">No chart data available.</p>
    }
    else
    {
        <div class="w-100 overflow-auto">
            <svg viewBox="0 0 @chartWidth @chartHeight" width="100%" height="@chartHeight" role="img" aria-label="@Model.Title">
                @for (var tick = minTemp; tick <= maxTemp; tick += tickStep)
                {
                    var y = paddingTop + plotHeight - ((tick - minTemp) / (double)tempRange * plotHeight);
                    <line x1="@paddingLeft" y1="@y.ToString(CultureInfo.InvariantCulture)" x2="@(chartWidth - paddingRight)" y2="@y.ToString(CultureInfo.InvariantCulture)"
                          stroke="#2f2f2f" stroke-dasharray="4 4"/>
                    @Html.Raw($"<text x=\"8\" y=\"{(y + 4).ToString(CultureInfo.InvariantCulture)}\" fill=\"#666666\" font-size=\"11\">{tick}°</text>")
                }

                <path d="@minimumPath" fill="none" stroke="#4da3ff" stroke-width="3" stroke-linecap="round"/>
                <path d="@averagePath" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round"/>
                <path d="@maximumPath" fill="none" stroke="#f59e42" stroke-width="3" stroke-linecap="round"/>

                @for (var i = 0; i < count; i++)
                {
                    var point = points[i];
                    var x = paddingLeft + (plotWidth / Math.Max(count - 1, 1)) * i;
                    var labelY = chartHeight - 12;
                    var labelStyle = point.IsHighlighted
                        ? "fill:#111111"
                        : "fill:#888888";
                    var badgeWidth = 72;
                    var badgeHeight = 24;
                    var badgeX = x - badgeWidth / 2;
                    var badgeY = labelY - 18;

                    if (point.IsHighlighted)
                    {
                        <rect x="@badgeX.ToString(CultureInfo.InvariantCulture)" y="@badgeY.ToString(CultureInfo.InvariantCulture)"
                              width="@badgeWidth" height="@badgeHeight" rx="12" fill="#ffffff"/>
                    }

                    @Html.Raw($"<text x=\"{x.ToString(CultureInfo.InvariantCulture)}\" y=\"{labelY.ToString(CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" font-size=\"11\" style=\"{labelStyle}\">{point.Label}</text>")
                }
            </svg>
        </div>
    }
</section>
