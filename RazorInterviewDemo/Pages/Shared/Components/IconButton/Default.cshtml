@model IconButtonModel

@{
    var shapeClass = Model.IsCircular ? "rounded-circle" : "rounded-pill";
    var sizeStyle = Model.IsCircular
        ? "width: 42px; height: 42px; padding: 0;"
        : "padding: 10px 18px;";
    var activeClass = Model.IsActive ? "is-active" : string.Empty;
}

<button type="button"
        class="btn d-inline-flex align-items-center justify-content-center gap-2 @shapeClass @Model.CssClass weather-icon-button @activeClass"
        style="@sizeStyle"
        data-action="@Model.Action">
    @if (!string.IsNullOrEmpty(Model.Icon))
    {
        @await Html.PartialAsync("_WeatherIcon", Model.Icon)
    }
    @if (!string.IsNullOrEmpty(Model.Text))
    {
        <span>@Model.Text</span>
    }
</button>
