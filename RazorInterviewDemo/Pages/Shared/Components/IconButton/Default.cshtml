@model IconButtonModel

@{
    var shapeClass = Model.IsCircular ? "rounded-circle" : "rounded-pill";
    var activeStyle = Model.IsActive
        ? "background-color: #ffffff; color: #111111; border: none;"
        : "background-color: #2a2a2a; color: #ffffff; border: 1px solid #3a3a3a;";
    var sizeStyle = Model.IsCircular
        ? "width: 42px; height: 42px; padding: 0;"
        : "padding: 10px 18px;";
}

<a href="@Model.Url"
   class="btn d-inline-flex align-items-center justify-content-center gap-2 @shapeClass @Model.CssClass"
   style="@activeStyle @sizeStyle font-size: 14px;">
    @if (!string.IsNullOrEmpty(Model.Icon))
    {
        @await Html.PartialAsync("_WeatherIcon", Model.Icon)
    }
    @if (!string.IsNullOrEmpty(Model.Text))
    {
        <span>@Model.Text</span>
    }
</a>
