@page "/"
@model RazorInterviewDemo.Pages.Weather.IndexModel
@{
    ViewData["Title"] = "Weather";
    Layout = "_WeatherLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/weather.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/pages/weather.js" asp-append-version="true"></script>
}

@if (Model.IsLoading)
{
    <div class="weather-dashboard container-fluid px-4 py-5">
        <div id="weather-loading" class="weather-loading rounded-4 p-5 text-center">
            <div class="spinner-border text-light mb-3" role="status" aria-hidden="true"></div>
            <p class="mb-1 weather-text-primary" style="font-size: 18px;">Detecting your location</p>
            <p class="mb-0 weather-text-muted" style="font-size: 14px;">Loading live weather from Open-Meteo</p>
        </div>
    </div>
}
else if (Model.HasError)
{
    <div class="weather-dashboard container-fluid px-4 py-5">
        <div class="weather-loading rounded-4 p-5 text-center">
            <p class="mb-3 weather-text-error">@Model.ErrorMessage</p>
            <button type="button"
                    class="btn rounded-pill px-4 weather-accent-btn"
                    data-action="refresh-weather">
                Retry
            </button>
        </div>
    </div>
}
else
{
    <div class="weather-dashboard container-fluid px-4 py-4">
        @await Component.InvokeAsync("TopBar", Model.Dashboard.TopBar)

        <div class="row g-4">
            <div class="col-xl-5">
                @await Component.InvokeAsync("WeatherSummary", Model.Dashboard.CurrentWeather)
                @await Component.InvokeAsync("ForecastCard", Model.Dashboard.Forecast)
            </div>
            <div class="col-xl-7">
                @await Component.InvokeAsync("TemperatureChart", Model.Dashboard.Chart)
            </div>
        </div>
    </div>
}
